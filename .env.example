# Anthropic API Key (for generating channeling letters)
ANTHROPIC_API_KEY=

# Shopify Webhook Secret (to verify webhook signatures)
SHOPIFY_WEBHOOK_SECRET=

# Shopify Admin API - Uruguay/LATAM store
SHOPIFY_UY_STORE_URL=
SHOPIFY_UY_ADMIN_API_KEY=

# Shopify Admin API - EEUU/International store
SHOPIFY_US_STORE_URL=
SHOPIFY_US_ADMIN_API_KEY=

# Resend API Key (for sending emails)
RESEND_API_KEY=

# App URL (your Vercel deployment URL)
APP_URL=https://magia.duendesdeluruguay.com

# Vercel Postgres (auto-configured by Vercel when you add the integration)
POSTGRES_URL=
